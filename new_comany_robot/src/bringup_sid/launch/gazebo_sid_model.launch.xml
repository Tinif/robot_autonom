<launch>
    <let name="urdf_path" 
        value="$(find-pkg-share sid_discription)/urdf/sid_model.urdf.xacro"/>
    
    <let name="rviz_config"
        value="$(find-pkg-share bringup_sid)/config/sid_rviz.rviz"/>


    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
            value="$(command 'xacro $(var urdf_path)')"/>

    </node>

    <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
    <arg name="world" value="/home/thinif/3_company_robot/src/bringup_sid/world/world_sid.world"/>
    
    </include>

    <node pkg="gazebo_ros" exec="spawn_entity.py" 
        args="-topic robot_description -entity sid_robot"/>
    
    <node pkg="rviz2" exec="rviz2" output="screen" 
        args="-d $(var rviz_config)"/>

</launch>