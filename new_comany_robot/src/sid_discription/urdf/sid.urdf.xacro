<?xml version="1.0"?>

<robot name="sid_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

   <xacro:include filename="comm_prop.xacro"/>

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
        <origin xyz="-0 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://sid_discription/meshes/body_urdf.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="cyan" />
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://sid_discription/meshes/body_urdf.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="cyan" />
        </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="47.873"/>
      <inertia ixx="3.474e+09" ixy="-2.147e+05" ixz="1.410e+06"
               iyy="3.420e+09" iyz="-5.477e+06"
               izz="8.326e+08"/>
    </inertial>
    </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_caster">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
     <xacro:caster_inertia m="1.0" xyz="0 0 0" rpy="0 0 0" r="0.05" />
  </link>

  <joint name="left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_caster"/>
    <origin xyz="0.09 0.04 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_caster">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
      <xacro:caster_inertia m="1.0" xyz="0 0 0" rpy="0 0 0" r="0.05" />
  </link>

  <joint name="right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_caster"/>
    <origin xyz="-0.09 0.04 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="left_wheel">
  <visual>
    <origin xyz="0 0 0" rpy="0 1.570 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.03"/>
    </geometry>
    <material name="grey" />
  </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 1.570 0" />
        </collision>
    <xacro:wheel_inertia m="1.0" xyz="0 0 0" rpy="0 1.570 0" r="0.05" h="0.03" />

  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.19 -0.23 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="right_wheel">
  <visual>
    <origin xyz="0 0 0" rpy="0 1.570 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.03"/>
    </geometry>
    <material name="grey"/>
  </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.03"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 1.570 0" />
        </collision>
    <xacro:wheel_inertia m="1.0" xyz="0 0 0" rpy="0 1.570 0" r="0.05" h="0.03" />
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.19 -0.23 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

    <link name="hand_right">
        <visual>
        <origin xyz="-0 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://sid_discription/meshes/hand_right.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="white" />
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://sid_discription/meshes/hand_right.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.770"/>
      <inertia ixx="3.600e+07" ixy="-1.402e+05" ixz="-2.640e+05"
               iyy="1.843e+07" iyz="-1.222e+07"
               izz="1.921e+07" />
    </inertial>
    </link>

  <joint name="right_hand" type="fixed">
    <parent link="base_link"/>
    <child link="hand_right"/>
    <origin xyz="-0.21 -0.15 1.08" rpy="0 0 0"/>
    <axis xyz="0 0 0"/>
  </joint>

    <link name="hand_left">
        <visual>
        <origin xyz="-0 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://sid_discription/meshes/left_hand.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="white" />
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://sid_discription/meshes/left_hand.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.770"/>
      <inertia ixx="3.598e+07" ixy="1.390e+05" ixz="2.614e+05"
               iyy="1.842e+07" iyz="-1.222e+07"
               izz="1.921e+07" />
    </inertial>
    </link>

  <joint name="left_hand" type="fixed">
    <parent link="base_link"/>
    <child link="hand_left"/>
    <origin xyz="0.21 -0.15 1.08" rpy="0 0 0"/>
    <axis xyz="0 0 0"/>
  </joint>

    <link name="head">
        <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://sid_discription/meshes/head_urdf.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://sid_discription/meshes/head_urdf.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.758"/>
      <inertia ixx="5.748e+07" ixy="-1621.058" ixz="350.07"
               iyy="5.837e+07" iyz="-51763.864"
               izz="5.127e+07" />
    </inertial>
    </link>
  
  <joint name="head_joint" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="-0.01 -0.1 1.47" rpy="0 0 0"/>
    <axis xyz="0 0 0"/>
  </joint>

  <xacro:include filename="mob_gazebo.xacro"/>

</robot>